PORT=3000
NODE_ENV=production

# Vozer login credentials (option 1: tu dong dang nhap)
VOZER_EMAIL=your_email@example.com
VOZER_PASSWORD=your_password

# Hoac su dung cookies truc tiep (option 2: uu tien hon neu co)
# Paste cookies tu browser vao day (format: key1=value1; key2=value2)
VOZER_COOKIES=
